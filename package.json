{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');['package-lock.json','yarn.lock'].forEach(f=>{try{fs.unlinkSync(f)}catch(e){}});\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "pg": "^8.20.0",
    "serverless-http": "^4.0.0"
  }
}