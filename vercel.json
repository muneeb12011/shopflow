{
  "version": 2,

  "installCommand": "pnpm install --no-frozen-lockfile",

  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/api-server build:serverless && pnpm --filter @workspace/shop build",

  "outputDirectory": "artifacts/shop/dist",

  "framework": null,

  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}