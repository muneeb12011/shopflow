# Copy this file to .env and fill in the values for local development

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/shopflow

# Optional: Session secret (any random string)
SESSION_SECRET=your-secret-key-here

# Shop frontend port (defaults to 3000 if not set)
PORT=3000

# API server port (defaults to 8080 if not set)
# The shop dev server will proxy /api/* requests to this port
API_PORT=8080
